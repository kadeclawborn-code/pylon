---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<BaseLayout title="Blog" description="Engineering posts from the Pylon team.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-16">
    <h1 class="text-3xl font-bold text-white mb-2">Blog</h1>
    <p class="text-pylon-slate mb-10">
      Engineering writing from the (synthetic) Pylon team. Posts are part of the Pylon benchmark substrate — they exist to give AI agents a corpus of in-character technical writing to reason against.
    </p>

    {posts.length === 0 ? (
      <p class="text-pylon-slate">No posts published yet. The first ones land in v0.2.0.</p>
    ) : (
      <ul class="space-y-8">
        {posts.map((post) => (
          <li>
            <a href={`/blog/${post.slug}/`} class="block hover:bg-pylon-surface-dark-dim/50 rounded -mx-3 px-3 py-2 transition-colors">
              <p class="text-pylon-slate font-mono text-xs mb-1">
                {post.data.publishedAt.toISOString().slice(0, 10)} · {post.data.author}
              </p>
              <h2 class="text-xl font-semibold text-white mb-1">{post.data.title}</h2>
              <p class="text-pylon-slate text-sm">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>
